<style>
  :root{
    --ink: #16302B;
    --ink-2: #1C231F;
    --canvas: #F6F5F1;
    --canvas-2: #EFEDE5;
    --amber: #B8863B;
    --amber-2: #9C7130;
    --sage: #7C9683;
    --line: #DAD6CB;
    --line-dark: rgba(246,245,241,0.16);
    --cream-text: #F2EFE6;
  }

  *{ box-sizing:border-box; margin:0; padding:0; }

  html{ scroll-behavior:smooth; }

  body{
    font-family:'Public Sans', sans-serif;
    color: var(--ink-2);
    background: var(--canvas);
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }

  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important; }
  }

  a{ color:inherit; }

  .display{
    font-family:'Fraunces', serif;
    font-optical-sizing:auto;
  }

  .mono{
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:0.06em;
    text-transform:uppercase;
  }

  .wrap{
    max-width:1120px;
    margin:0 auto;
    padding:0 32px;
  }

  /* ---------- NAV ---------- */
  header.site-nav{
    position:fixed;
    top:0; left:0; right:0;
    z-index:100;
    background:rgba(22,48,43,0.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line-dark);
  }
  .nav-inner{
    max-width:1120px;
    margin:0 auto;
    padding:18px 32px;
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  .nav-mark{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.15rem;
    color:var(--cream-text);
    letter-spacing:0.01em;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .nav-mark svg{ flex-shrink:0; }
  nav.nav-links{
    display:flex;
    gap:32px;
    align-items:center;
  }
  nav.nav-links a{
    text-decoration:none;
    color:var(--cream-text);
    font-size:0.92rem;
    opacity:0.85;
    transition:opacity 0.2s ease;
  }
  nav.nav-links a:hover{ opacity:1; }
  .btn{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:'Public Sans', sans-serif;
    font-weight:600;
    font-size:0.92rem;
    padding:11px 22px;
    border-radius:3px;
    text-decoration:none;
    cursor:pointer;
    border:1px solid transparent;
    transition:transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .btn-amber{
    background:var(--amber);
    color:#1C1204;
  }
  .btn-amber:hover{
    background:var(--amber-2);
    transform:translateY(-1px);
    box-shadow:0 6px 18px rgba(184,134,59,0.35);
  }
  .btn-ghost{
    border-color:rgba(242,239,230,0.4);
    color:var(--cream-text);
    background:transparent;
  }
  .btn-ghost:hover{ border-color:var(--cream-text); }

  .mobile-toggle{ display:none; }

  /* ---------- HERO ---------- */
  .hero{
    background:var(--ink);
    color:var(--cream-text);
    padding:170px 0 0 0;
    position:relative;
    overflow:hidden;
  }
  .hero-inner{
    max-width:1120px;
    margin:0 auto;
    padding:0 32px 120px 32px;
    position:relative;
    z-index:2;
  }
  .eyebrow{
    font-size:0.78rem;
    color:var(--amber);
    margin-bottom:22px;
    display:flex;
    align-items:center;
    gap:12px;
  }
  .eyebrow::before{
    content:'';
    width:28px; height:1px;
    background:var(--amber);
    display:inline-block;
  }
  .hero h1{
    font-size:clamp(2.6rem, 5.4vw, 4.4rem);
    font-weight:500;
    line-height:1.06;
    max-width:820px;
    letter-spacing:-0.01em;
  }
  .hero h1 em{
    font-style:italic;
    font-weight:500;
    color:var(--sage);
  }
  .hero p.lede{
    margin-top:26px;
    max-width:520px;
    font-size:1.08rem;
    color:rgba(242,239,230,0.78);
  }
  .hero-actions{
    margin-top:40px;
    display:flex;
    gap:16px;
    flex-wrap:wrap;
  }

  .horizon-wrap{
    position:relative;
    height:220px;
    margin-top:90px;
  }
  .horizon-wrap svg{
    position:absolute;
    bottom:0; left:0;
    width:100%;
    height:100%;
    overflow:visible;
  }
  .horizon-line{
    fill:none;
    stroke:var(--amber);
    stroke-width:2;
    stroke-linecap:round;
    stroke-dasharray:1400;
    stroke-dashoffset:1400;
    animation:draw 2.2s cubic-bezier(0.65,0,0.35,1) 0.3s forwards;
  }
  .horizon-line-fill{
    fill:url(#horizonGradient);
    opacity:0;
    animation:fadeIn 1.6s ease 1.4s forwards;
  }
  .horizon-dot{
    opacity:0;
    animation:fadeIn 0.6s ease 2.3s forwards;
  }
  .horizon-dot .ball-body{ fill:var(--cream-text); }
  .horizon-dot .ball-dimple{ fill:var(--ink); opacity:0.35; }
  .tee-marker{
    opacity:0;
    animation:fadeIn 0.5s ease 0.1s forwards;
  }
  .tee-marker .tee-peg{ stroke:var(--sage); stroke-width:2; }
  .tee-marker .tee-ball{ fill:var(--sage); }
  @keyframes draw{ to{ stroke-dashoffset:0; } }
  @keyframes fadeIn{ to{ opacity:1; } }

  /* ---------- SERVICES ---------- */
  .services{
    padding:110px 0 100px 0;
    background:var(--canvas);
  }
  .section-head{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:40px;
    margin-bottom:64px;
    flex-wrap:wrap;
  }
  .section-head .mono{
    font-size:0.76rem;
    color:var(--amber-2);
    margin-bottom:14px;
    display:block;
  }
  .section-head h2{
    font-size:clamp(1.9rem, 3.4vw, 2.6rem);
    font-weight:500;
    max-width:560px;
    line-height:1.15;
  }
  .section-head p{
    max-width:340px;
    color:#5B655F;
    font-size:0.97rem;
  }

  .service-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    border-top:1px solid var(--line);
    border-left:1px solid var(--line);
  }
  .service-card{
    border-right:1px solid var(--line);
    border-bottom:1px solid var(--line);
    padding:40px 34px;
    transition:background 0.25s ease;
  }
  .service-card:hover{
    background:var(--canvas-2);
  }
  .service-card .mono{
    font-size:0.7rem;
    color:var(--sage);
    display:block;
    margin-bottom:18px;
  }
  .service-card h3{
    font-family:'Fraunces', serif;
    font-weight:500;
    font-size:1.28rem;
    margin-bottom:12px;
    letter-spacing:-0.01em;
  }
  .service-card p{
    color:#5B655F;
    font-size:0.94rem;
  }

  /* ---------- ABOUT ---------- */
  .about{
    background:var(--canvas-2);
    padding:110px 0;
  }
  .about-inner{
    display:grid;
    grid-template-columns:0.85fr 1.15fr;
    gap:72px;
    align-items:start;
  }
  .about-photo{
    position:relative;
  }
  .about-photo img{
    width:100%;
    display:block;
    border-radius:2px;
    filter:grayscale(8%);
  }
  .about-photo::before{
    content:'';
    position:absolute;
    top:-18px; left:-18px;
    width:100%; height:100%;
    border:1.5px solid var(--amber);
    z-index:-1;
    border-radius:2px;
  }
  .about-text .mono{
    font-size:0.76rem;
    color:var(--amber-2);
    margin-bottom:14px;
    display:block;
  }
  .about-text h2{
    font-size:clamp(1.9rem, 3vw, 2.4rem);
    font-weight:500;
    margin-bottom:26px;
    line-height:1.18;
  }
  .about-text p{
    color:#3E453F;
    font-size:1rem;
    margin-bottom:18px;
    max-width:560px;
  }
  .credentials{
    margin-top:34px;
    padding-top:28px;
    border-top:1px solid var(--line);
    display:grid;
    grid-template-columns:repeat(2, 1fr);
    gap:20px;
    max-width:560px;
  }
  .credentials div .mono{
    font-size:0.68rem;
    color:var(--sage);
    display:block;
    margin-bottom:6px;
  }
  .credentials div p{
    font-size:0.92rem;
    color:var(--ink-2);
    margin:0;
    font-weight:600;
  }
  .social-line{
    margin-top:30px;
    display:flex;
    gap:20px;
    align-items:center;
  }
  .social-line a{
    text-decoration:none;
    font-size:0.9rem;
    font-weight:600;
    color:var(--amber-2);
    border-bottom:1px solid var(--amber-2);
    padding-bottom:2px;
  }

  /* ---------- CONTACT ---------- */
  .contact{
    background:var(--ink);
    color:var(--cream-text);
    padding:0 0 110px 0;
    position:relative;
  }
  .contact-topline{
    height:64px;
    position:relative;
    overflow:hidden;
  }
  .contact-topline svg{ width:100%; height:100%; display:block; }
  .contact-topline path{
    fill:none;
    stroke:var(--sage);
    stroke-width:1.4;
    opacity:0.55;
  }
  .contact-inner{
    max-width:1120px;
    margin:0 auto;
    padding:60px 32px 0 32px;
    display:grid;
    grid-template-columns:0.9fr 1.1fr;
    gap:80px;
  }
  .contact-info .mono{
    font-size:0.76rem;
    color:var(--amber);
    display:block;
    margin-bottom:14px;
  }
  .contact-info h2{
    font-size:clamp(2rem, 3.6vw, 2.7rem);
    font-weight:500;
    line-height:1.14;
    margin-bottom:22px;
  }
  .contact-info p{
    color:rgba(242,239,230,0.72);
    font-size:1rem;
    max-width:400px;
    margin-bottom:30px;
  }
  .contact-detail{
    margin-bottom:16px;
  }
  .contact-detail .mono{
    font-size:0.68rem;
    color:var(--sage);
    margin-bottom:4px;
  }
  .contact-detail a, .contact-detail span{
    font-size:1rem;
    color:var(--cream-text);
    text-decoration:none;
  }
  .contact-detail a:hover{ color:var(--amber); }

  form.consult-form{
    display:flex;
    flex-direction:column;
    gap:20px;
  }
  .form-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
  }
  .field{
    display:flex;
    flex-direction:column;
    gap:8px;
  }
  .field label{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.68rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--sage);
  }
  .field input, .field textarea{
    background:transparent;
    border:none;
    border-bottom:1px solid rgba(242,239,230,0.3);
    padding:10px 2px;
    color:var(--cream-text);
    font-family:'Public Sans', sans-serif;
    font-size:0.98rem;
    outline:none;
    transition:border-color 0.2s ease;
  }
  .field input:focus, .field textarea:focus{
    border-color:var(--amber);
  }
  .field textarea{ resize:vertical; min-height:90px; }
  .field input::placeholder, .field textarea::placeholder{
    color:rgba(242,239,230,0.32);
  }
  .consult-form .btn{
    margin-top:8px;
    align-self:flex-start;
  }
  .form-note{
    font-size:0.82rem;
    color:rgba(242,239,230,0.5);
    margin-top:2px;
  }
  .form-confirm{
    display:none;
    background:rgba(124,150,131,0.15);
    border:1px solid var(--sage);
    padding:16px 18px;
    font-size:0.92rem;
    border-radius:3px;
    color:var(--cream-text);
  }

  /* ---------- FOOTER ---------- */
  footer{
    background:var(--ink);
    border-top:1px solid var(--line-dark);
    padding:32px 0;
  }
  .footer-inner{
    max-width:1120px;
    margin:0 auto;
    padding:0 32px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:14px;
  }
  .footer-inner p{
    font-size:0.8rem;
    color:rgba(242,239,230,0.45);
  }
  .footer-inner .mono{
    font-size:0.7rem;
    color:rgba(242,239,230,0.4);
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 860px){
    nav.nav-links{ display:none; }
    .about-inner{ grid-template-columns:1fr; gap:48px; }
    .about-photo{ max-width:340px; }
    .contact-inner{ grid-template-columns:1fr; gap:50px; }
    .service-grid{ grid-template-columns:1fr 1fr; }
    .form-row{ grid-template-columns:1fr; }
  }
  @media (max-width: 560px){
    .wrap, .nav-inner, .hero-inner, .contact-inner, .footer-inner{ padding-left:20px; padding-right:20px; }
    .service-grid{ grid-template-columns:1fr; }
    .hero{ padding-top:130px; }
    .credentials{ grid-template-columns:1fr; }
  }
</style>
</head>
