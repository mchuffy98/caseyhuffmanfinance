          <div class="field">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555">
          </div>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@email.com" required>
        </div>
        <div class="field">
          <label for="message">What's on your mind?</label>
          <textarea id="message" name="message" placeholder="A little about your goals or situation..."></textarea>
        </div>
        <button type="submit" class="btn btn-amber">Send &amp; book a time</button>
        <p class="form-note">This opens your email client with your message pre-filled to Casey.</p>
        <div class="form-confirm" id="formConfirm">Thanks — your email client should now be open with your message ready to send.</div>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="footer-inner">
    <p>© <span id="year"></span> Casey Huffman · Keenan Financial. All investments involve risk, including possible loss of principal.</p>
    <span class="mono">Fiduciary planning, plainly explained</span>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  const form = document.getElementById('consultForm');
  form.addEventListener('submit', function(e){
    e.preventDefault();
    const name = document.getElementById('name').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const email = document.getElementById('email').value.trim();
    const message = document.getElementById('message').value.trim();

    const subject = encodeURIComponent('Free consultation request — ' + name);
    const bodyLines = [
      'Name: ' + name,
      'Email: ' + email,
      'Phone: ' + (phone || 'Not provided'),
      '',
      'Message:',
      message || '(No additional message)'
    ];
    const body = encodeURIComponent(bodyLines.join('\n'));

    window.location.href = 'mailto:casey@keenanfinancial.com?subject=' + subject + '&body=' + body;

    const confirm = document.getElementById('formConfirm');
    confirm.style.display = 'block';
  });
</script>

</body>
</html>
